@page "/posts/new"
@page "/posts/{id:guid}/edit"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>@(IsEdit ? L["Editor_EditPost"] : L["Editor_NewPost"])</PageTitle>

<h2 class="mb-4">@(IsEdit ? L["Editor_EditPost"] : L["Editor_NewPost"])</h2>

<AlertMessage @bind-Message="error" Type="AlertMessage.AlertType.Danger" />

<MarkdownEditor @bind-Title="title"
                @bind-Content="content"
                @bind-IsPublished="isPublished"
                OnSave="Save"
                OnDelete="Delete"
                ShowDelete="IsEdit"
                SaveButtonText="@(IsEdit ? L["Editor_Update"] : L["Editor_Create"])"
                IsLoading="isLoading" />

@* ImageUploader - zeigt existierende Bilder und erlaubt Upload/Löschung *@
@if (IsEdit)
{
    <ImageUploader PostId="Id!.Value" OnImageMarkdown="InsertMarkdown" />
}

@* SocialEmbed - zeigt Vorschau der erkannten Links aus dem Content *@
<SocialEmbed Content="content" />

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsEdit => Id.HasValue;
    private string title = "";
    private string content = "";
    private bool isPublished;
    private string? error;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            try
            {
                var post = await Api.GetPostAsync(Id!.Value);
                if (post is not null)
                {
                    title = post.Title;
                    content = post.Content;
                    isPublished = post.IsPublished;
                }
                else
                {
                    error = L["Editor_PostNotFound"];
                }
            }
            catch (Exception ex)
            {
                error = L["Common_SomethingWentWrong", ex.Message];
            }
        }
    }

    private void InsertMarkdown(string markdown)
    {
        content += "\n\n" + markdown;
    }

    private async Task Save()
    {
        isLoading = true;
        error = null;

        try
        {
            var dto = new PostDto(Guid.Empty, title, content, Guid.Empty, isPublished, DateTime.UtcNow, null, null);

            if (IsEdit)
            {
                var result = await Api.UpdatePostAsync(Id!.Value, dto);
                if (result is not null) Navigation.NavigateTo($"/posts/{Id}");
                else error = L["Editor_FailedUpdate"];
            }
            else
            {
                var result = await Api.CreatePostAsync(dto);
                if (result is not null)
                {
                    if (result.IsPublished)
                        Navigation.NavigateTo($"/posts/{result.Id}");
                    else
                        Navigation.NavigateTo("/my/posts");
                }
                else error = L["Editor_FailedCreate"];
            }
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Delete()
    {
        if (!IsEdit) return;
        error = null;

        try
        {
            if (await Api.DeletePostAsync(Id!.Value))
                Navigation.NavigateTo("/");
            else
                error = L["Editor_FailedDelete"];
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }
}
