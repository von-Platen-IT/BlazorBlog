@page "/profile"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>@L["Nav_Profile"]</PageTitle>

<h2 class="mb-4">👤 @L["Profile_Title"]</h2>

@if (user is null)
{
    <p>@L["Common_Loading"]</p>
}
else
{
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header d-flex align-items-center gap-2">
                    <span class="fs-4">👤</span>
                    <span class="fw-bold fs-5">@user.UserName</span>
                    @if (user.IsRoot)
                    {
                        <Badge Color="Color.Warning" Class="ms-auto">@L["Profile_RootBadge"]</Badge>
                    }
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">@L["Profile_Username"]</dt>
                        <dd class="col-sm-8">@user.UserName</dd>
                        <dt class="col-sm-4">@L["Profile_Email"]</dt>
                        <dd class="col-sm-8">@(user.Email ?? L["Profile_EmailNotSet"])</dd>
                        <dt class="col-sm-4">@L["Profile_Groups"]</dt>
                        <dd class="col-sm-8">
                            @if (user.Groups.Count == 0)
                            {
                                <span class="text-muted">@L["Profile_NoGroups"]</span>
                            }
                            else
                            {
                                @foreach (var g in user.Groups)
                                {
                                    <Badge Color="Color.Primary" Class="me-1">@g</Badge>
                                }
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private AuthUserInfo? user;

    protected override async Task OnInitializedAsync()
    {
        user = await Api.GetCurrentUserAsync();
        if (user is null)
        {
            Navigation.NavigateTo("/login");
        }
    }
}
