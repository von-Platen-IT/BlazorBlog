@page "/posts/{id:guid}"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>@(post?.Title ?? L["Nav_Brand"])</PageTitle>

<AlertMessage @bind-Message="actionError" Type="AlertMessage.AlertType.Danger" Dismissible="false" />
<AlertMessage @bind-Message="actionSuccess" Type="AlertMessage.AlertType.Success" Dismissible="false" />

@if (post is null)
{
    <p>@L["Common_Loading"]</p>
}
else
{
    <PostContent Post="post">
        @MarkdownRenderer.ToHtml(post.Content)
    </PostContent>

    @if (!post.IsPublished && isOwner)
    {
        @* Draft: Publish & Delete actions, no comments *@
        <div class="d-flex gap-2 mb-4 p-3 bg-warning bg-opacity-10 rounded border border-warning">
            <button class="btn btn-success"
                    @onclick="PublishPostAsync"
                    disabled="@isActionLoading">
                @(isActionLoading ? L["PostDetail_Publishing"] : L["PostDetail_PublishNow"])
            </button>
            <button class="btn btn-outline-danger"
                    @onclick='() => showDeleteConfirm = true'
                    disabled="@isActionLoading">
                @L["PostDetail_DeleteDraft"]
            </button>
            <a href='/posts/@post.Id/edit' class="btn btn-outline-primary">@L["PostDetail_Edit"]</a>
        </div>

        @* Delete Confirmation Modal *@
        <DeleteConfirmModal IsVisible="showDeleteConfirm"
                            Title="@L["PostDetail_DeleteTitle"]"
                            Message="@L["PostDetail_DeleteMessage", post.Title]"
                            IsDisabled="isActionLoading"
                            OnConfirm="DeleteDraftAsync"
                            OnCancel='() => showDeleteConfirm = false' />
    }
    else
    {
        @* Published: Rating, Bookmark & Comments *@
        <RatingBar PostId="Id"
                   LikeCount="likeCount"
                   DislikeCount="dislikeCount"
                   UserRating="userRating"
                   IsAuthenticated="isAuthenticated"
                   IsBookmarked="isBookmarked"
                   OnLike="ToggleLike"
                   OnDislike="ToggleDislike"
                   OnToggleBookmark="ToggleBookmark" />

        <hr />

        <CommentSection PostId="Id" />
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private PostDto? post;
    private bool isAuthenticated;
    private bool isOwner;
    private int likeCount;
    private int dislikeCount;
    private string? userRating;
    private bool isBookmarked;
    private bool isActionLoading;
    private bool showDeleteConfirm;
    private string? actionError;
    private string? actionSuccess;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            post = await Api.GetPostAsync(Id);

            if (post is null)
            {
                actionError = L["PostDetail_PostNotFound", Id];
                return;
            }

            var user = await Api.GetCurrentUserAsync();
            isAuthenticated = user is not null;

            if (user is not null)
            {
                isOwner = post.AuthorId.ToString() == user.UserId || user.IsRoot || user.Groups.Contains("Admin");
            }

            if (post.IsPublished)
            {
                var rating = await Api.GetPostRatingAsync(Id);
                if (rating is not null)
                {
                    likeCount = rating.LikeCount;
                    dislikeCount = rating.DislikeCount;
                    userRating = rating.UserRating;
                }

                if (isAuthenticated)
                {
                    var bm = await Api.GetBookmarkStatusAsync(Id);
                    isBookmarked = bm?.IsBookmarked ?? false;
                }
            }
        }
        catch (Exception ex)
        {
            actionError = L["Common_SomethingWentWrong", $"{ex.GetType().Name}: {ex.Message}"];
        }
    }

    private async Task PublishPostAsync()
    {
        if (post is null || isActionLoading) return;
        isActionLoading = true;
        actionError = null;
        actionSuccess = null;

        try
        {
            var updated = post with { IsPublished = true };
            var result = await Api.UpdatePostAsync(Id, updated);
            if (result is not null)
            {
                actionSuccess = L["PostDetail_Published"];
                // Reload to show the published view
                Navigation.NavigateTo($"/posts/{Id}", forceLoad: true);
            }
            else
            {
                actionError = L["PostDetail_FailedPublish"];
                isActionLoading = false;
            }
        }
        catch (Exception ex)
        {
            actionError = L["Common_SomethingWentWrong", ex.Message];
            isActionLoading = false;
        }
    }

    private async Task DeleteDraftAsync()
    {
        if (isActionLoading) return;
        isActionLoading = true;
        actionError = null;
        showDeleteConfirm = false;

        try
        {
            var success = await Api.DeletePostAsync(Id);
            if (success)
            {
                Navigation.NavigateTo("/my/posts");
            }
            else
            {
                actionError = L["PostDetail_FailedDelete"];
                isActionLoading = false;
            }
        }
        catch (Exception ex)
        {
            actionError = L["Common_SomethingWentWrong", ex.Message];
            isActionLoading = false;
        }
    }

    private async Task ToggleLike()
    {
        if (!isAuthenticated) return;
        try
        {
            var result = await Api.LikePostAsync(Id);
            if (result is not null)
            {
                likeCount = result.LikeCount;
                dislikeCount = result.DislikeCount;
                userRating = result.UserRating;
            }
        }
        catch (Exception ex)
        {
            actionError = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task ToggleDislike()
    {
        if (!isAuthenticated) return;
        try
        {
            var result = await Api.DislikePostAsync(Id);
            if (result is not null)
            {
                likeCount = result.LikeCount;
                dislikeCount = result.DislikeCount;
                userRating = result.UserRating;
            }
        }
        catch (Exception ex)
        {
            actionError = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task ToggleBookmark()
    {
        if (!isAuthenticated) return;
        try
        {
            var result = await Api.ToggleBookmarkAsync(Id);
            if (result is not null) isBookmarked = result.IsBookmarked;
        }
        catch (Exception ex)
        {
            actionError = L["Common_SomethingWentWrong", ex.Message];
        }
    }

}
