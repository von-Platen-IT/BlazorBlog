@page "/admin/settings"
@rendermode InteractiveServer
@inject ApiClient Api

<PageTitle>@L["Nav_Settings"]</PageTitle>

<h2 class="mb-4">⚙️ @L["Settings_Title"]</h2>

<AlertMessage @bind-Message="error" Type="AlertMessage.AlertType.Danger" />
<AlertMessage @bind-Message="successMessage" Type="AlertMessage.AlertType.Success" />

@if (settings is null)
{
    <p>@L["Common_Loading"]</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var s in settings)
        {
            <div class="col">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="card-title text-muted text-uppercase small">@s.Key</h6>
                        <div class="input-group">
                            <input class="form-control form-control-sm" @bind="editValues[s.Key]" />
                            <Button Color="Color.Primary" Size="Size.Small" OnClick="() => Save(s.Key)">@L["Settings_Save"]</Button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<SettingDto>? settings;
    private Dictionary<string, string> editValues = [];
    private string? error;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            settings = await Api.GetSettingsAsync();
            if (settings is not null)
            {
                foreach (var s in settings)
                    editValues[s.Key] = s.Value ?? "";
            }
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task Save(string key)
    {
        error = null;
        successMessage = null;
        try
        {
            await Api.UpdateSettingAsync(key, editValues.GetValueOrDefault(key, ""));
            successMessage = L["Settings_Saved", key];
            settings = await Api.GetSettingsAsync();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }
}
