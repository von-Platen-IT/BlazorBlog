@page "/admin/moderation"
@rendermode InteractiveServer
@inject ApiClient Api

<PageTitle>@L["Nav_Moderation"]</PageTitle>

<h2 class="mb-4">✅ @L["Mod_Title"]</h2>

<AlertMessage @bind-Message="error" Type="AlertMessage.AlertType.Danger" />
<AlertMessage @bind-Message="successMessage" Type="AlertMessage.AlertType.Success" />

@if (comments is null)
{
    <p>@L["Common_Loading"]</p>
}
else if (comments.Count == 0)
{
    <div class="text-center py-5">
        <h4 class="text-muted">@L["Mod_NoPending"]</h4>
        <p class="text-secondary">@L["Mod_AllReviewed"]</p>
    </div>
}
else
{
    <div class="mb-3 d-flex gap-2">
        <Button Color="Color.Success" OnClick="BulkApprove" IsDisabled="selectedIds.Count == 0">
            @L["Mod_ApproveSelected", selectedIds.Count]
        </Button>
        <Button Color="Color.Danger" OnClick="BulkReject" IsDisabled="selectedIds.Count == 0">
            @L["Mod_RejectSelected", selectedIds.Count]
        </Button>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th style="width:40px"><input type="checkbox" @onchange="ToggleAll" /></th>
                    <th>@L["Mod_ColAuthor"]</th>
                    <th>@L["Mod_ColPost"]</th>
                    <th>@L["Mod_ColContent"]</th>
                    <th>@L["Mod_ColDate"]</th>
                    <th style="width:180px">@L["Mod_ColActions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in comments)
                {
                    <tr>
                        <td>
                            <input type="checkbox" checked="@selectedIds.Contains(c.Id)"
                                   @onchange="() => ToggleSelect(c.Id)" />
                        </td>
                        <td>@(c.GuestName ?? L["Common_Guest"])</td>
                        <td>
                            <a href="/posts/@c.PostId" target="_blank" rel="noopener" title="@L["Mod_OpenPost"]">
                                @(c.PostTitle ?? c.PostId.ToString())
                            </a>
                        </td>
                        <td>
                            @if (c.Content.Length <= 200)
                            {
                                @c.Content
                            }
                            else if (expandedComments.Contains(c.Id))
                            {
                                @c.Content
                                <button class="btn btn-link btn-sm p-0 ms-1"
                                        @onclick="() => expandedComments.Remove(c.Id)">
                                    @L["Mod_ShowLess"]
                                </button>
                            }
                            else
                            {
                                @(c.Content[..200] + "…")
                                <button class="btn btn-link btn-sm p-0 ms-1"
                                        @onclick="() => expandedComments.Add(c.Id)">
                                    @L["Mod_ShowMore"]
                                </button>
                            }
                        </td>
                        <td class="text-nowrap small">@c.CreatedAt.ToString("g")</td>
                        <td>
                            <Button Color="Color.Success" Size="Size.Small" OnClick="() => Approve(c.Id)">@L["Mod_Approve"]</Button>
                            <Button Color="Color.Danger" Size="Size.Small" OnClick="() => Reject(c.Id)">@L["Mod_Reject"]</Button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private const int ContentPreviewLength = 200;
    private List<CommentDto>? comments;
    private HashSet<Guid> selectedIds = [];
    private HashSet<Guid> expandedComments = [];
    private string? error;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            comments = await Api.GetPendingCommentsAsync();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private void ToggleSelect(Guid id)
    {
        if (selectedIds.Contains(id)) selectedIds.Remove(id);
        else selectedIds.Add(id);
    }

    private void ToggleAll(ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false) && comments is not null)
            selectedIds = comments.Select(c => c.Id).ToHashSet();
        else
            selectedIds.Clear();
    }

    private async Task Approve(Guid id)
    {
        error = null;
        try
        {
            await Api.ApproveCommentAsync(id);
            successMessage = L["Mod_Approved"];
            comments = await Api.GetPendingCommentsAsync();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task Reject(Guid id)
    {
        error = null;
        try
        {
            await Api.RejectCommentAsync(id);
            successMessage = L["Mod_Rejected"];
            comments = await Api.GetPendingCommentsAsync();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task BulkApprove()
    {
        error = null;
        try
        {
            await Api.BulkApproveAsync(selectedIds.ToList());
            successMessage = L["Mod_BulkApproved", selectedIds.Count];
            selectedIds.Clear();
            comments = await Api.GetPendingCommentsAsync();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task BulkReject()
    {
        error = null;
        try
        {
            await Api.BulkRejectAsync(selectedIds.ToList());
            successMessage = L["Mod_BulkRejected", selectedIds.Count];
            selectedIds.Clear();
            comments = await Api.GetPendingCommentsAsync();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }
}
