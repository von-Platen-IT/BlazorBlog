@page "/login"
@rendermode InteractiveServer

<PageTitle>@L["Login_Title"]</PageTitle>

@* Read error from query string (set by AuthController on failed login) *@
@if (!string.IsNullOrEmpty(loginError))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        ❌ @loginError
        <button type="button" class="btn-close" @onclick='() => loginError = null'
                @onclick:stopPropagation></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <h2>@L["Login_Title"]</h2>

        <form method="post" action="/api/auth/login">
            <div class="mb-3">
                <label class="form-label">@L["Login_Username"]</label>
                <input type="text" name="userName" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Login_Password"]</label>
                <input type="password" name="password" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-3">
                @L["Login_Button"]
            </button>
        </form>

        <hr />
        <p class="text-center">@L["Login_OrLoginWith"]</p>
        <div class="d-flex gap-2 justify-content-center">
            <a href="/api/auth/login/google" class="btn btn-outline-danger">Google</a>
            <a href="/api/auth/login/github" class="btn btn-outline-dark">GitHub</a>
            <a href="/api/auth/login/microsoft" class="btn btn-outline-primary">Microsoft</a>
        </div>

        <p class="mt-3 text-center">
            @L["Login_NoAccount"] <a href="/register">@L["Login_RegisterLink"]</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? LoginErrorFromQuery { get; set; }

    private string? loginError;

    protected override void OnInitialized()
    {
        loginError = LoginErrorFromQuery;
    }
}
