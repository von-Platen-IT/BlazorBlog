@page "/my/posts"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>My Posts</PageTitle>

<h2 class="mb-4">📋 My Posts</h2>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div class="btn-group" role="group">
        <button class="btn @(filter == "all" ? "btn-primary" : "btn-outline-primary")"
                @onclick='async () => await ApplyFilter("all")'>
            All
        </button>
        <button class="btn @(filter == "published" ? "btn-primary" : "btn-outline-primary")"
                @onclick='async () => await ApplyFilter("published")'>
            ✅ Published
        </button>
        <button class="btn @(filter == "drafts" ? "btn-primary" : "btn-outline-primary")"
                @onclick='async () => await ApplyFilter("drafts")'>
            📝 Drafts
        </button>
        <button class="btn @(filter == "bookmarks" ? "btn-primary" : "btn-outline-primary")"
                @onclick='async () => await ApplyFilter("bookmarks")'>
            🔖 Bookmarks
        </button>
    </div>
    <a href="/posts/new" class="btn btn-success">✏️ New Post</a>
</div>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}

@if (successMessage is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" @onclick='() => successMessage = null'></button>
    </div>
}

@if (allPosts is null)
{
    <p>Loading...</p>
}
else if (filteredPosts.Count == 0)
{
    <div class="text-center py-5">
        <h4 class="text-muted">
            @(filter == "drafts" ? "No drafts." : filter == "published" ? "No published posts." : filter == "bookmarks" ? "No bookmarked posts." : "No posts yet.")
        </h4>
        @if (filter != "bookmarks")
        {
            <a href="/posts/new" class="btn btn-primary mt-2">Write your first post</a>
        }
    </div>
}
else if (filter == "bookmarks" && bookmarkedPosts is not null)
{
    @* Bookmarks: Desktop Table *@
    <div class="d-none d-md-block">
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th class="text-center">👍</th>
                        <th class="text-center">👎</th>
                        <th class="text-center">💬</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in bookmarkedPosts)
                    {
                        <tr>
                            <td>
                                <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                   href="/posts/@post.Id" class="text-decoration-none fw-semibold">
                                    @post.Title
                                </a>
                                <div class="text-muted small">@Truncate(post.Content, 80)</div>
                            </td>
                            <td class="text-muted small">@post.AuthorName</td>
                            <td class="text-center">@post.LikeCount</td>
                            <td class="text-center">@post.DislikeCount</td>
                            <td class="text-center">
                                @if (post.CommentCount > 0)
                                {
                                    <span class="badge bg-info">@post.CommentCount</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <Button Color="Color.Primary" Size="Size.Small" OnClick='() => GoToPost(post.Id)'>View</Button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Bookmarks: Mobile Cards *@
    <div class="d-md-none">
        <div class="row g-3">
            @foreach (var post in bookmarkedPosts)
            {
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title mb-1">
                                <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                   href="/posts/@post.Id" class="text-decoration-none">
                                    @post.Title
                                </a>
                            </h6>
                            <p class="card-text text-muted small mb-2">@Truncate(post.Content, 100)</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-muted small">by @post.AuthorName</span>
                                    <span class="ms-2">👍 @post.LikeCount</span>
                                    <span class="ms-1">👎 @post.DislikeCount</span>
                                    @if (post.CommentCount > 0)
                                    {
                                        <span class="badge bg-info ms-2">💬 @post.CommentCount</span>
                                    }
                                </div>
                                <Button Color="Color.Primary" Size="Size.Small" OnClick='() => GoToPost(post.Id)'>View</Button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    @* Desktop: Table view *@
    <div class="d-none d-md-block">
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th class="text-center">💬 Comments</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in filteredPosts)
                    {
                        <tr>
                            <td>
                                <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                   href="/posts/@post.Id" class="text-decoration-none fw-semibold">
                                    @post.Title
                                </a>
                                <div class="text-muted small">@Truncate(post.Content, 80)</div>
                            </td>
                            <td>
                                @if (post.IsPublished)
                                {
                                    <Badge Color="Color.Success">Published</Badge>
                                }
                                else
                                {
                                    <Badge Color="Color.Warning">Draft</Badge>
                                }
                            </td>
                            <td class="text-center">
                                @if (post.CommentCount > 0)
                                {
                                    <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                       href="/posts/@post.Id" class="badge bg-info text-decoration-none">
                                        @post.CommentCount
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-muted small">@post.CreatedAt.ToString("d")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <Button Color="Color.Primary" OnClick='() => EditPost(post.Id)' Tooltip="Edit">
                                        ✏️
                                    </Button>
                                    @if (!post.IsPublished)
                                    {
                                        <Button Color="Color.Success" OnClick='async () => await PublishPost(post.Id)' Tooltip="Publish">
                                            ✅
                                        </Button>
                                    }
                                    <Button Color="Color.Danger" OnClick='() => ConfirmDelete(post.Id, post.Title)' Tooltip="Delete">
                                        🗑️
                                    </Button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Mobile: Card view *@
    <div class="d-md-none">
        <div class="row g-3">
            @foreach (var post in filteredPosts)
            {
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="card-title mb-0">
                                    <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                       href="/posts/@post.Id" class="text-decoration-none">
                                        @post.Title
                                    </a>
                                </h6>
                                @if (post.IsPublished)
                                {
                                    <Badge Color="Color.Success">Published</Badge>
                                }
                                else
                                {
                                    <Badge Color="Color.Warning">Draft</Badge>
                                }
                            </div>
                            <p class="card-text text-muted small mb-2">@Truncate(post.Content, 100)</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-muted small">@post.CreatedAt.ToString("d")</span>
                                    @if (post.CommentCount > 0)
                                    {
                                        <span class="badge bg-info ms-2">💬 @post.CommentCount</span>
                                    }
                                </div>
                                <div class="btn-group btn-group-sm">
                                    <Button Color="Color.Primary" OnClick='() => EditPost(post.Id)'>✏️</Button>
                                    @if (!post.IsPublished)
                                    {
                                        <Button Color="Color.Success" OnClick='async () => await PublishPost(post.Id)'>✅</Button>
                                    }
                                    <Button Color="Color.Danger" OnClick='() => ConfirmDelete(post.Id, post.Title)'>🗑️</Button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* Pagination *@
    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-center mt-4">
            <nav>
                <ul class="pagination">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick='async () => await LoadPage(currentPage - 1)'>«</button>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <button class="page-link" @onclick='async () => await LoadPage(i)'>@i</button>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick='async () => await LoadPage(currentPage + 1)'>»</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
}

@* Delete Confirmation Modal *@
@if (deleteTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Post</h5>
                    <button type="button" class="btn-close" @onclick='() => deleteTarget = null'></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong>"@deleteTitle"</strong>?</p>
                    <p class="text-danger small mb-0">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <Button Color="Color.Secondary" OnClick='() => deleteTarget = null'>Cancel</Button>
                    <Button Color="Color.Danger" OnClick="ExecuteDelete" IsDisabled="isDeleting">
                        @(isDeleting ? "Deleting..." : "Delete")
                    </Button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MyPostDto>? allPosts;
    private List<MyPostDto> filteredPosts = new();
    private List<BookmarkedPostDto>? bookmarkedPosts;
    private string filter = "all";
    private int currentPage = 1;
    private int totalPages = 1;
    private string? error;
    private string? successMessage;
    private Guid? deleteTarget;
    private string deleteTitle = "";
    private bool isDeleting;

    protected override async Task OnInitializedAsync()
    {
        var user = await Api.GetCurrentUserAsync();
        if (user is null)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        await LoadPage(1);
    }

    private async Task LoadPage(int page)
    {
        error = null;
        if (filter == "bookmarks")
        {
            var result = await Api.GetBookmarkedPostsAsync(page, 10);
            if (result is not null)
            {
                bookmarkedPosts = result.Posts;
                currentPage = result.Page;
                totalPages = (int)Math.Ceiling(result.Total / (double)10);
            }
            else
            {
                error = "Failed to load bookmarks.";
            }
        }
        else
        {
            var result = await Api.GetMyPostsAsync(page, 10);
            if (result is not null)
            {
                allPosts = result.Posts;
                currentPage = result.Page;
                totalPages = (int)Math.Ceiling(result.Total / (double)10);
                ApplyFilterLocal();
            }
            else
            {
                error = "Failed to load posts.";
            }
        }
    }

    private async Task ApplyFilter(string newFilter)
    {
        filter = newFilter;
        currentPage = 1;
        if (filter == "bookmarks")
        {
            await LoadPage(1);
        }
        else
        {
            if (allPosts is null) await LoadPage(1);
            else ApplyFilterLocal();
        }
        StateHasChanged();
    }

    private void ApplyFilterLocal()
    {
        if (allPosts is null) { filteredPosts = new(); return; }
        filteredPosts = filter switch
        {
            "published" => allPosts.Where(p => p.IsPublished).ToList(),
            "drafts" => allPosts.Where(p => !p.IsPublished).ToList(),
            _ => allPosts
        };
    }

    private void GoToPost(Guid id) => Navigation.NavigateTo($"/posts/{id}");

    private void EditPost(Guid id) => Navigation.NavigateTo($"/posts/{id}/edit");

    private async Task PublishPost(Guid id)
    {
        error = null;
        // Get the full post, set IsPublished = true, update
        var post = await Api.GetPostAsync(id);
        if (post is null) { error = "Post not found."; return; }

        var updated = post with { IsPublished = true };
        var result = await Api.UpdatePostAsync(id, updated);
        if (result is not null)
        {
            successMessage = "Post published successfully!";
            await LoadPage(currentPage);
        }
        else
        {
            error = "Failed to publish post.";
        }
    }

    private void ConfirmDelete(Guid id, string title)
    {
        deleteTarget = id;
        deleteTitle = title;
    }

    private async Task ExecuteDelete()
    {
        if (deleteTarget is null) return;
        isDeleting = true;
        var success = await Api.DeletePostAsync(deleteTarget.Value);
        isDeleting = false;
        deleteTarget = null;

        if (success)
        {
            successMessage = "Post deleted.";
            await LoadPage(currentPage);
        }
        else
        {
            error = "Failed to delete post.";
        }
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength] + "...";
}