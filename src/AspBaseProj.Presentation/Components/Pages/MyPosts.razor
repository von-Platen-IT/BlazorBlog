@page "/my/posts"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>@L["Nav_MyPosts"]</PageTitle>

<h2 class="mb-4">📋 @L["MyPosts_Title"]</h2>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div class="btn-group" role="group">
        <button class="btn @(filter == "all" ? "btn-primary" : "btn-outline-primary")"
                @onclick='async () => await ApplyFilter("all")'>
            @L["MyPosts_All"]
        </button>
        <button class="btn @(filter == "published" ? "btn-primary" : "btn-outline-primary")"
                @onclick='async () => await ApplyFilter("published")'>
            ✅ @L["MyPosts_Published"]
        </button>
        <button class="btn @(filter == "drafts" ? "btn-primary" : "btn-outline-primary")"
                @onclick='async () => await ApplyFilter("drafts")'>
            📝 @L["MyPosts_Drafts"]
        </button>
        <button class="btn @(filter == "bookmarks" ? "btn-primary" : "btn-outline-primary")"
                @onclick='async () => await ApplyFilter("bookmarks")'>
            🔖 @L["MyPosts_Bookmarks"]
        </button>
    </div>
    <a href="/posts/new" class="btn btn-success">✏️ @L["MyPosts_NewPost"]</a>
</div>

<AlertMessage @bind-Message="error" Type="AlertMessage.AlertType.Danger" />
<AlertMessage @bind-Message="successMessage" Type="AlertMessage.AlertType.Success" />

@if (allPosts is null && filter != "bookmarks")
{
    <p>@L["Common_Loading"]</p>
}
else if (bookmarkedPosts is null && filter == "bookmarks")
{
    <p>@L["Common_Loading"]</p>
}
else if (filteredPosts.Count == 0 && filter != "bookmarks")
{
    <div class="text-center py-5">
        <h4 class="text-muted">
            @(filter == "drafts" ? L["MyPosts_NoDrafts"] : filter == "published" ? L["MyPosts_NoPublished"] : L["MyPosts_NoPosts"])
        </h4>
        <a href="/posts/new" class="btn btn-primary mt-2">@L["Home_WriteFirstPost"]</a>
    </div>
}
else if (bookmarkedPosts?.Count == 0 && filter == "bookmarks")
{
    <div class="text-center py-5">
        <h4 class="text-muted">@L["MyPosts_NoBookmarks"]</h4>
    </div>
}
else if (filter == "bookmarks" && bookmarkedPosts is not null)
{
    @* Bookmarks: Desktop Table *@
    <div class="d-none d-md-block">
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>@L["MyPosts_ColTitle"]</th>
                        <th>@L["MyPosts_ColAuthor"]</th>
                        <th class="text-center">👍</th>
                        <th class="text-center">👎</th>
                        <th class="text-center">💬</th>
                        <th class="text-end">@L["MyPosts_ColActions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in bookmarkedPosts)
                    {
                        <tr>
                            <td>
                                <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                   href="/posts/@post.Id" class="text-decoration-none fw-semibold">
                                    @post.Title
                                </a>
                                <div class="text-muted small">@Truncate(post.Content, 80)</div>
                            </td>
                            <td class="text-muted small">@post.AuthorName</td>
                            <td class="text-center">@post.LikeCount</td>
                            <td class="text-center">@post.DislikeCount</td>
                            <td class="text-center">
                                @if (post.CommentCount > 0)
                                {
                                    <span class="badge bg-info">@post.CommentCount</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <Button Color="Color.Primary" Size="Size.Small" OnClick='() => GoToPost(post.Id)'>@L["Common_View"]</Button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Bookmarks: Mobile Cards *@
    <div class="d-md-none">
        <div class="row g-3">
            @foreach (var post in bookmarkedPosts)
            {
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title mb-1">
                                <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                   href="/posts/@post.Id" class="text-decoration-none">
                                    @post.Title
                                </a>
                            </h6>
                            <p class="card-text text-muted small mb-2">@Truncate(post.Content, 100)</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-muted small">@L["PostList_By"] @post.AuthorName</span>
                                    <span class="ms-2">👍 @post.LikeCount</span>
                                    <span class="ms-1">👎 @post.DislikeCount</span>
                                    @if (post.CommentCount > 0)
                                    {
                                        <span class="badge bg-info ms-2">💬 @post.CommentCount</span>
                                    }
                                </div>
                                <Button Color="Color.Primary" Size="Size.Small" OnClick='() => GoToPost(post.Id)'>@L["Common_View"]</Button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    @* Desktop: Table view *@
    <div class="d-none d-md-block">
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>@L["MyPosts_ColTitle"]</th>
                        <th>@L["MyPosts_ColStatus"]</th>
                        <th class="text-center">@L["MyPosts_ColComments"]</th>
                        <th>@L["MyPosts_ColCreated"]</th>
                        <th class="text-end">@L["MyPosts_ColActions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in filteredPosts)
                    {
                        <tr>
                            <td>
                                <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                   href="/posts/@post.Id" class="text-decoration-none fw-semibold">
                                    @post.Title
                                </a>
                                <div class="text-muted small">@Truncate(post.Content, 80)</div>
                            </td>
                            <td>
                                @if (post.IsPublished)
                                {
                                    <Badge Color="Color.Success">@L["MyPosts_BadgePublished"]</Badge>
                                }
                                else
                                {
                                    <Badge Color="Color.Warning">@L["MyPosts_BadgeDraft"]</Badge>
                                }
                            </td>
                            <td class="text-center">
                                @if (post.CommentCount > 0)
                                {
                                    <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                       href="/posts/@post.Id" class="badge bg-info text-decoration-none">
                                        @post.CommentCount
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-muted small">@post.CreatedAt.ToString("d")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <Button Color="Color.Primary" OnClick='() => EditPost(post.Id)' Tooltip="@L["MyPosts_TooltipEdit"]">
                                        ✏️
                                    </Button>
                                    @if (!post.IsPublished)
                                    {
                                        <Button Color="Color.Success" OnClick='async () => await PublishPost(post.Id)' Tooltip="@L["MyPosts_TooltipPublish"]">
                                            ✅
                                        </Button>
                                    }
                                    <Button Color="Color.Danger" OnClick='() => ConfirmDelete(post.Id, post.Title)' Tooltip="@L["MyPosts_TooltipDelete"]">
                                        🗑️
                                    </Button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Mobile: Card view *@
    <div class="d-md-none">
        <div class="row g-3">
            @foreach (var post in filteredPosts)
            {
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="card-title mb-0">
                                    <a @onclick='() => GoToPost(post.Id)' @onclick:preventDefault
                                       href="/posts/@post.Id" class="text-decoration-none">
                                        @post.Title
                                    </a>
                                </h6>
                                @if (post.IsPublished)
                                {
                                    <Badge Color="Color.Success">@L["MyPosts_BadgePublished"]</Badge>
                                }
                                else
                                {
                                    <Badge Color="Color.Warning">@L["MyPosts_BadgeDraft"]</Badge>
                                }
                            </div>
                            <p class="card-text text-muted small mb-2">@Truncate(post.Content, 100)</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-muted small">@post.CreatedAt.ToString("d")</span>
                                    @if (post.CommentCount > 0)
                                    {
                                        <span class="badge bg-info ms-2">💬 @post.CommentCount</span>
                                    }
                                </div>
                                <div class="btn-group btn-group-sm">
                                    <Button Color="Color.Primary" OnClick='() => EditPost(post.Id)'>✏️</Button>
                                    @if (!post.IsPublished)
                                    {
                                        <Button Color="Color.Success" OnClick='async () => await PublishPost(post.Id)'>✅</Button>
                                    }
                                    <Button Color="Color.Danger" OnClick='() => ConfirmDelete(post.Id, post.Title)'>🗑️</Button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* Pagination *@
    <Pager CurrentPage="currentPage" TotalPages="totalPages" OnPageChanged="LoadPage" />
}

@* Delete Confirmation Modal *@
<DeleteConfirmModal IsVisible="deleteTarget is not null"
                    Title="@L["MyPosts_DeleteTitle"]"
                    Message="@L["MyPosts_DeleteMessage", deleteTitle]"
                    IsDisabled="isDeleting"
                    OnConfirm="ExecuteDelete"
                    OnCancel='() => deleteTarget = null' />

@code {
    private List<MyPostDto>? allPosts;
    private List<MyPostDto> filteredPosts = new();
    private List<BookmarkedPostDto>? bookmarkedPosts;
    private string filter = "all";
    private int currentPage = 1;
    private int totalPages = 1;
    private string? error;
    private string? successMessage;
    private Guid? deleteTarget;
    private string deleteTitle = "";
    private bool isDeleting;

    protected override async Task OnInitializedAsync()
    {
        var user = await Api.GetCurrentUserAsync();
        if (user is null)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        await LoadPage(1);
    }

    private async Task LoadPage(int page)
    {
        error = null;
        try
        {
            if (filter == "bookmarks")
            {
                var result = await Api.GetBookmarkedPostsAsync(page, 10);
                if (result is not null)
                {
                    bookmarkedPosts = result.Posts;
                    currentPage = result.Page;
                    totalPages = (int)Math.Ceiling(result.Total / (double)10);
                }
                else
                {
                    error = L["MyPosts_FailedLoadBookmarks"];
                }
            }
            else
            {
                var result = await Api.GetMyPostsAsync(page, 10);
                if (result is not null)
                {
                    allPosts = result.Posts;
                    currentPage = result.Page;
                    totalPages = (int)Math.Ceiling(result.Total / (double)10);
                    ApplyFilterLocal();
                }
                else
                {
                    error = L["MyPosts_FailedLoad"];
                }
            }
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task ApplyFilter(string newFilter)
    {
        filter = newFilter;
        currentPage = 1;
        if (filter == "bookmarks")
        {
            await LoadPage(1);
        }
        else
        {
            if (allPosts is null) await LoadPage(1);
            else ApplyFilterLocal();
        }
        StateHasChanged();
    }

    private void ApplyFilterLocal()
    {
        if (allPosts is null) { filteredPosts = new(); return; }
        filteredPosts = filter switch
        {
            "published" => allPosts.Where(p => p.IsPublished).ToList(),
            "drafts" => allPosts.Where(p => !p.IsPublished).ToList(),
            _ => allPosts
        };
    }

    private void GoToPost(Guid id) => Navigation.NavigateTo($"/posts/{id}");

    private void EditPost(Guid id) => Navigation.NavigateTo($"/posts/{id}/edit");

    private async Task PublishPost(Guid id)
    {
        error = null;
        try
        {
            var post = await Api.GetPostAsync(id);
            if (post is null) { error = L["MyPosts_PostNotFound"]; return; }

            var updated = post with { IsPublished = true };
            var result = await Api.UpdatePostAsync(id, updated);
            if (result is not null)
            {
                successMessage = L["MyPosts_PublishedSuccess"];
                await LoadPage(currentPage);
            }
            else
            {
                error = L["MyPosts_FailedPublish"];
            }
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private void ConfirmDelete(Guid id, string title)
    {
        deleteTarget = id;
        deleteTitle = title;
    }

    private async Task ExecuteDelete()
    {
        if (deleteTarget is null) return;
        isDeleting = true;
        error = null;
        try
        {
            var success = await Api.DeletePostAsync(deleteTarget.Value);
            deleteTarget = null;

            if (success)
            {
                successMessage = L["MyPosts_DeletedSuccess"];
                await LoadPage(currentPage);
            }
            else
            {
                error = L["MyPosts_FailedDelete"];
            }
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
        finally
        {
            isDeleting = false;
        }
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength] + "...";
}
