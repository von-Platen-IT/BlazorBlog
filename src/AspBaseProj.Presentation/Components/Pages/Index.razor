@page "/"
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Nav_Brand"]</PageTitle>

<div class="text-center py-5">
    <h1 class="display-4 fw-bold mb-3">📝 @L["Nav_Brand"]</h1>
    <p class="lead text-muted mb-4">@L["Start_Welcome"]</p>
    <a href="/blog" class="btn btn-primary btn-lg">@L["Start_ViewBlog"]</a>
</div>

<div class="row g-4 mt-3">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h5 class="card-title">📝 @L["Start_FeaturePosts_Title"]</h5>
                <p class="card-text text-muted">@L["Start_FeaturePosts_Text"]</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h5 class="card-title">💬 @L["Start_FeatureComments_Title"]</h5>
                <p class="card-text text-muted">@L["Start_FeatureComments_Text"]</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h5 class="card-title">🔒 @L["Start_FeatureRoles_Title"]</h5>
                <p class="card-text text-muted">@L["Start_FeatureRoles_Text"]</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-5">
    <h2 class="mb-3">@L["Start_AboutTitle"]</h2>
    <p class="text-muted">@L["Start_AboutText"]</p>
</div>
