@page "/blog"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>@L["Nav_Brand"]</PageTitle>

<h1 class="mb-4">@L["Home_Title"]</h1>

<AlertMessage @bind-Message="error" Type="AlertMessage.AlertType.Danger" />

@if (posts is null)
{
    <p>@L["Common_Loading"]</p>
}
else if (posts.Count == 0)
{
    <div class="text-center py-5">
        <h4 class="text-muted">@L["Home_NoPosts"]</h4>
        @if (isAuthenticated)
        {
            <a href="/posts/new" class="btn btn-primary mt-2">@L["Home_WriteFirstPost"]</a>
        }
    </div>
}
else
{
    <PostList Posts="posts" OnViewPost="GoToPost" />

    <Pager CurrentPage="currentPage" TotalPages="totalPages" OnPageChanged="LoadPage" />
}

@code {
    private List<PostDto>? posts;
    private int currentPage = 1;
    private int totalPages = 1;
    private bool isAuthenticated;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        var user = await Api.GetCurrentUserAsync();
        isAuthenticated = user is not null;
        await LoadPage(1);
    }

    private async Task LoadPage(int page)
    {
        error = null;
        try
        {
            var result = await Api.GetPostsAsync(page, 9);
            if (result is not null)
            {
                posts = result.Posts;
                currentPage = result.Page;
                totalPages = (int)Math.Ceiling(result.Total / (double)9);
            }
            else
            {
                error = L["MyPosts_FailedLoad"];
            }
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private void GoToPost(Guid id) => Navigation.NavigateTo($"/posts/{id}");
}
