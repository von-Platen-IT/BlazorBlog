@page "/register"
@rendermode InteractiveServer

<PageTitle>@L["Register_Title"]</PageTitle>

@* Read error from query string (set by AuthController on failed registration) *@
@if (!string.IsNullOrEmpty(registerError))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        ❌ @registerError
        <button type="button" class="btn-close" @onclick='() => registerError = null'
                @onclick:stopPropagation></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <h2>@L["Register_Title"]</h2>

        <form method="post" action="/api/auth/register">
            <div class="mb-3">
                <label class="form-label">@L["Register_Username"]</label>
                <input type="text" name="userName" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Register_EmailOptional"]</label>
                <input type="email" name="email" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Register_Password"]</label>
                <input type="password" name="password" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-3">
                @L["Register_Button"]
            </button>
        </form>

        <hr />
        <p class="text-center">@L["Register_OrSignUpWith"]</p>
        <div class="d-flex gap-2 justify-content-center">
            <a href="/api/auth/login/google" class="btn btn-outline-danger">Google</a>
            <a href="/api/auth/login/github" class="btn btn-outline-dark">GitHub</a>
            <a href="/api/auth/login/microsoft" class="btn btn-outline-primary">Microsoft</a>
        </div>

        <p class="mt-3 text-center">
            @L["Register_HaveAccount"] <a href="/login">@L["Register_LoginLink"]</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? RegisterErrorFromQuery { get; set; }

    private string? registerError;

    protected override void OnInitialized()
    {
        registerError = RegisterErrorFromQuery;
    }
}
