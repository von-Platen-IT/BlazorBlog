@page "/privacy"
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Legal_Privacy"]</PageTitle>

<h1 class="mb-4">@L["Legal_Privacy"]</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="card-title">@L["Legal_PrivacyHeading"]</h5>
        <p class="text-muted">@L["Legal_PrivacyText"]</p>
    </div>
</div>