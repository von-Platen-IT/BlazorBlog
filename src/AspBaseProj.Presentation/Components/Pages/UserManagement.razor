@page "/admin/users"
@rendermode InteractiveServer
@inject ApiClient Api

<PageTitle>@L["Nav_Users"]</PageTitle>

<h2 class="mb-4">👥 @L["Users_Title"]</h2>

<AlertMessage @bind-Message="error" Type="AlertMessage.AlertType.Danger" />
<AlertMessage @bind-Message="successMessage" Type="AlertMessage.AlertType.Success" />

@if (users is null || allGroups is null)
{
    <p>@L["Common_Loading"]</p>
}
else
{
    <div class="mb-3 p-3 bg-light rounded border d-flex align-items-center gap-2 flex-wrap">
        <span class="fw-bold me-2">@L["Users_BulkActions"]</span>
        <span class="text-muted small me-2">@L["Users_Selected", selectedRows.Count]</span>
        <div class="dropdown d-inline">
            <Button Color="Color.Success" Size="Size.Small" class="dropdown-toggle" data-bs-toggle="dropdown"
                    IsDisabled="selectedRows.Count == 0">
                @L["Users_AssignGroup"]
            </Button>
            <ul class="dropdown-menu">
                @foreach (var g in allGroups)
                {
                    <li>
                        <button class="dropdown-item" @onclick="() => BulkAssignGroup(g.Id)">@g.Name</button>
                    </li>
                }
            </ul>
        </div>
        <div class="dropdown d-inline">
            <Button Color="Color.Warning" Size="Size.Small" class="dropdown-toggle" data-bs-toggle="dropdown"
                    IsDisabled="selectedRows.Count == 0">
                @L["Users_RemoveGroup"]
            </Button>
            <ul class="dropdown-menu">
                @foreach (var g in allGroups)
                {
                    <li>
                        <button class="dropdown-item" @onclick="() => BulkRemoveGroup(g.Id)">@g.Name</button>
                    </li>
                }
            </ul>
        </div>
        <Button Color="Color.Danger" Size="Size.Small" OnClick="BulkDelete" IsDisabled="selectedRows.Count == 0">
            🗑️ @L["Users_DeleteSelected"]
        </Button>
    </div>

    <Table TItem="UserDisplayRow" Items="displayRows"
           PageItemsSource="new int[] { 10, 25, 50 }" IsPagination="true" IsStriped="true"
           IsMultipleSelect="true" @bind-SelectedRows="selectedRows">
        <TableColumns>
            <TableColumn @bind-Field="@context.UserName" Text="@L["Users_ColUsername"]" />
            <TableColumn @bind-Field="@context.Email" Text="@L["Users_ColEmail"]" />
            <TableColumn @bind-Field="@context.GroupsDisplay" Text="@L["Users_ColGroups"]" />
            <TableColumn @bind-Field="@context.IsRootDisplay" Text="@L["Users_ColRoot"]" />
        </TableColumns>
        <RowButtonTemplate>
            @if (!context.IsRoot)
            {
                <div class="dropdown d-inline me-1">
                    <Button Color="Color.Secondary" Size="Size.Small" class="dropdown-toggle" data-bs-toggle="dropdown">@L["Users_AddGroup"]</Button>
                    <ul class="dropdown-menu">
                        @foreach (var g in allGroups.Where(g => !context.UserGroups.Contains(g.Name)))
                        {
                            <li>
                                <button class="dropdown-item" @onclick="() => AddGroup(context.UserId, g.Id)">@g.Name</button>
                            </li>
                        }
                    </ul>
                </div>
                @foreach (var g in context.UserGroups)
                {
                    <Button Color="Color.Warning" Size="Size.Small" OnClick="() => RemoveGroup(context.UserId, g)" Class="me-1">- @g</Button>
                }
                <Button Color="Color.Danger" Size="Size.Small" OnClick="() => DeleteUser(context.UserId)">🗑️</Button>
            }
            else
            {
                <Badge Color="Color.Warning">@L["Users_RootCannotModify"]</Badge>
            }
        </RowButtonTemplate>
    </Table>
}

@code {
    private List<UserDto>? users;
    private List<GroupDto>? allGroups;
    private List<UserDisplayRow>? displayRows;
    private List<UserDisplayRow> selectedRows = [];
    private string? error;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    private async Task AddGroup(Guid userId, Guid groupId)
    {
        error = null;
        try
        {
            await Api.AssignGroupAsync(userId, groupId);
            successMessage = L["Users_GroupAssigned"];
            await Reload();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task RemoveGroup(Guid userId, string groupName)
    {
        error = null;
        try
        {
            var group = allGroups?.FirstOrDefault(g => g.Name == groupName);
            if (group is not null)
            {
                await Api.RemoveGroupAsync(userId, group.Id);
                successMessage = L["Users_GroupRemoved"];
                await Reload();
            }
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task DeleteUser(Guid userId)
    {
        error = null;
        try
        {
            await Api.DeleteUserAsync(userId);
            successMessage = L["Users_UserDeleted"];
            await Reload();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task BulkAssignGroup(Guid groupId)
    {
        error = null;
        try
        {
            foreach (var row in selectedRows.Where(r => !r.IsRoot))
                await Api.AssignGroupAsync(row.UserId, groupId);
            successMessage = L["Users_BulkGroupAssigned"];
            selectedRows.Clear();
            await Reload();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task BulkRemoveGroup(Guid groupId)
    {
        error = null;
        try
        {
            foreach (var row in selectedRows.Where(r => !r.IsRoot))
                await Api.RemoveGroupAsync(row.UserId, groupId);
            successMessage = L["Users_BulkGroupRemoved"];
            selectedRows.Clear();
            await Reload();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task BulkDelete()
    {
        error = null;
        try
        {
            foreach (var row in selectedRows.Where(r => !r.IsRoot))
                await Api.DeleteUserAsync(row.UserId);
            successMessage = L["Users_BulkDeleted"];
            selectedRows.Clear();
            await Reload();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private async Task Reload()
    {
        try
        {
            users = await Api.GetUsersAsync();
            allGroups = await Api.GetGroupsAsync();
            RefreshDisplay();
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
    }

    private void RefreshDisplay()
    {
        displayRows = users?.Select(u => new UserDisplayRow
        {
            UserId = u.Id,
            UserName = u.UserName,
            Email = u.Email ?? "-",
            GroupsDisplay = u.Groups.Count > 0 ? string.Join(", ", u.Groups) : "-",
            IsRootDisplay = u.IsRoot ? $"✅ {L["Common_Yes"]}" : L["Common_No"],
            IsRoot = u.IsRoot,
            UserGroups = u.Groups
        }).ToList();
    }

    private class UserDisplayRow
    {
        public Guid UserId { get; set; }
        public string UserName { get; set; } = "";
        public string Email { get; set; } = "";
        public string GroupsDisplay { get; set; } = "";
        public string IsRootDisplay { get; set; } = "";
        public bool IsRoot { get; set; }
        public List<string> UserGroups { get; set; } = [];
    }
}
