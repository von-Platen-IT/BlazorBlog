@using AspBaseProj.Presentation.Components.Shared
@inject ApiClient Api

<div class="comment-thread @(Depth > 0 ? "comment-thread--nested" : "")">
    <div class="comment-node">
        <div class="d-flex justify-content-between align-items-start mb-1">
            <div>
                <strong class="me-2">@(Comment.User?.UserName ?? Comment.GuestName ?? "Anonymous")</strong>
                @if (!Comment.IsApproved)
                {
                    <span class="badge bg-warning text-dark me-2">⏳ Pending Approval</span>
                }
                <small class="text-muted">@Comment.CreatedAt.ToString("g")</small>
            </div>
        </div>
        <p class="mb-2">@Comment.Content</p>

        @if (Comment.IsApproved)
        {
            <button class="btn btn-sm btn-link p-0 text-decoration-none"
                    @onclick='() => showReplyForm = !showReplyForm'>
                💬 Reply
            </button>
        }

        @if (showReplyForm)
        {
            <div class="mt-2 p-2 bg-light rounded">
                @if (!IsAuthenticated)
                {
                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <input class="form-control form-control-sm" placeholder="Your Name" @bind="replyGuestName" />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control form-control-sm" placeholder="Your Email" @bind="replyGuestEmail" />
                        </div>
                    </div>
                }
                <textarea class="form-control form-control-sm mb-2" rows="2"
                          @bind="replyText" @bind:event="oninput"
                          placeholder="Write a reply..."></textarea>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-primary"
                            @onclick="SubmitReplyAsync"
                            disabled="@(string.IsNullOrWhiteSpace(replyText) || isSubmitting)">
                        @(isSubmitting ? "Posting..." : "Submit Reply")
                    </button>
                    <button class="btn btn-sm btn-secondary"
                            @onclick='() => { showReplyForm = false; replyText = ""; }'>
                        Cancel
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(replyError))
                {
                    <div class="text-danger small mt-1">@replyError</div>
                }
            </div>
        }

        @if (Comment.Replies is { Count: > 0 })
        {
            <div class="mt-2">
                @foreach (var reply in Comment.Replies)
                {
                    <CommentNode Comment="reply" Depth="Depth + 1" IsAuthenticated="IsAuthenticated" />
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public required CommentDto Comment { get; set; }
    [Parameter] public int Depth { get; set; }
    [Parameter] public bool IsAuthenticated { get; set; }

    private bool showReplyForm;
    private string replyText = "";
    private string replyGuestName = "";
    private string replyGuestEmail = "";
    private bool isSubmitting;
    private string? replyError;

    private async Task SubmitReplyAsync()
    {
        if (string.IsNullOrWhiteSpace(replyText) || isSubmitting) return;
        isSubmitting = true;
        replyError = null;

        var result = await Api.ReplyToCommentAsync(Comment.Id, replyText, replyGuestName, replyGuestEmail);

        if (result is not null)
        {
            // Optimistic insert: add the new reply directly to the parent's Replies list
            Comment.Replies.Add(result);
            showReplyForm = false;
            replyText = "";
            replyGuestName = "";
            replyGuestEmail = "";
        }
        else
        {
            replyError = "Failed to post reply. Please try again.";
        }

        isSubmitting = false;
    }
}