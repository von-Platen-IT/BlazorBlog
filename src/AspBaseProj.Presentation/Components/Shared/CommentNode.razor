@using AspBaseProj.Presentation.Components.Shared
@inject ApiClient Api

<div class="comment-thread @(Depth > 0 ? "comment-thread--nested" : "")"
     style="--comment-depth: @Depth">
    <div class="comment-node">
        <div class="d-flex justify-content-between align-items-start mb-1">
            <div>
                <strong class="me-2">@(Comment.User?.UserName ?? Comment.GuestName ?? L["Comments_Anonymous"])</strong>
                @if (!Comment.IsApproved)
                {
                    <span class="badge bg-warning text-dark me-2">@L["Comments_PendingApproval"]</span>
                }
                <small class="text-muted">@Comment.CreatedAt.ToString("g")</small>
            </div>
        </div>
        <p class="mb-2">@Comment.Content</p>

        @if (Comment.IsApproved && Depth < MaxDepth)
        {
            <button class="btn btn-sm btn-link p-0 text-decoration-none"
                    @onclick='() => showReplyForm = !showReplyForm'>
                @L["Comments_Reply"]
            </button>
        }
        else if (Depth >= MaxDepth && Comment.Replies.Count > 0)
        {
            <small class="text-muted">@L["Comments_RepliesClosed"]</small>
        }

        @if (showReplyForm)
        {
            <div class="mt-2 p-2 bg-light rounded">
                @if (!IsAuthenticated)
                {
                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <input class="form-control form-control-sm" placeholder="@L["Comments_PlaceholderName"]" @bind="replyGuestName" />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control form-control-sm" placeholder="@L["Comments_PlaceholderEmail"]" @bind="replyGuestEmail" />
                        </div>
                    </div>
                }
                <textarea class="form-control form-control-sm mb-1" rows="2"
                          @bind="replyText" @bind:event="oninput"
                          placeholder="@L["Comments_ReplyPlaceholder"]"></textarea>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <small class="@(replyText.Length > MaxCommentLength ? "text-danger fw-bold" : "text-muted")">
                        @L["Comments_CharCount", replyText.Length, MaxCommentLength]
                    </small>
                    <small class="text-muted">@L["Comments_MaxLengthHint", MaxCommentLength]</small>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-primary"
                            @onclick="SubmitReplyAsync"
                            disabled="@(string.IsNullOrWhiteSpace(replyText) || isSubmitting || replyText.Length > MaxCommentLength)">
                        @(isSubmitting ? L["Comments_Posting"] : L["Comments_SubmitReply"])
                    </button>
                    <button class="btn btn-sm btn-secondary"
                            @onclick='() => { showReplyForm = false; replyText = ""; }'>
                        @L["Common_Cancel"]
                    </button>
                </div>
                <AlertMessage @bind-Message="replyError" Type="AlertMessage.AlertType.Danger" Dismissible="true" />
            </div>
        }

        @if (Comment.Replies is { Count: > 0 })
        {
            <div class="mt-2">
                @foreach (var reply in Comment.Replies)
                {
                    <CommentNode Comment="reply" Depth="Depth + 1" IsAuthenticated="IsAuthenticated" />
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public required CommentDto Comment { get; set; }
    [Parameter] public int Depth { get; set; }
    [Parameter] public bool IsAuthenticated { get; set; }

    private const int MaxDepth = 5;
    private const int MaxCommentLength = 8000;

    private bool showReplyForm;
    private string replyText = "";
    private string replyGuestName = "";
    private string replyGuestEmail = "";
    private bool isSubmitting;
    private string? replyError;

    private async Task SubmitReplyAsync()
    {
        if (string.IsNullOrWhiteSpace(replyText) || isSubmitting) return;
        isSubmitting = true;
        replyError = null;

        try
        {
            var result = await Api.ReplyToCommentAsync(Comment.Id, replyText, replyGuestName, replyGuestEmail);

            if (result is not null)
            {
                // Optimistic insert: add the new reply directly to the parent's Replies list
                Comment.Replies.Add(result);
                showReplyForm = false;
                replyText = "";
                replyGuestName = "";
                replyGuestEmail = "";
            }
            else
            {
                replyError = L["Comments_FailedReply"];
            }
        }
        catch (Exception ex)
        {
            replyError = L["Common_SomethingWentWrong", ex.Message];
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
