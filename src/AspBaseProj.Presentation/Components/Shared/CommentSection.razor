@using AspBaseProj.Presentation.Components.Shared
@inject ApiClient Api

<div class="comment-section mt-4">
    @if (isLoading)
    {
        <p class="text-muted">@L["Common_Loading"]</p>
    }
    else
    {
        <h3 class="mb-3">@L["Comments_Title"] @(comments.Count > 0 ? $"({comments.Count})" : "")</h3>

        <AlertMessage @bind-Message="error" Type="AlertMessage.AlertType.Danger" />

        @* Top-Level Comment Form *@
        @if (!showGuestThankYou)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@L["Comments_AddTitle"]</h5>
                    @if (!isAuthenticated)
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-6">
                                <input class="form-control form-control-sm" placeholder="@L["Comments_PlaceholderName"]"
                                       @bind="newCommentGuestName" />
                            </div>
                            <div class="col-md-6">
                                <input class="form-control form-control-sm" placeholder="@L["Comments_PlaceholderEmail"]"
                                       @bind="newCommentGuestEmail" />
                            </div>
                        </div>
                    }
                    <textarea class="form-control mb-1" rows="3" @bind="newCommentText"
                              @bind:event="oninput"
                              placeholder="@L["Comments_PlaceholderText"]"></textarea>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="@(newCommentText.Length > MaxCommentLength ? "text-danger fw-bold" : "text-muted")">
                            @L["Comments_CharCount", newCommentText.Length, MaxCommentLength]
                        </small>
                        <small class="text-muted">@L["Comments_MaxLengthHint", MaxCommentLength]</small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-primary"
                                @onclick="SubmitTopLevelCommentAsync"
                                disabled="@(string.IsNullOrWhiteSpace(newCommentText) || isSubmitting || newCommentText.Length > MaxCommentLength)">
                            @(isSubmitting ? L["Comments_Posting"] : L["Comments_Submit"])
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-success shadow-sm mb-4" role="alert">
                <h5 class="alert-heading">@L["Comments_ThankYouTitle"]</h5>
                <p class="mb-0">@L["Comments_ThankYouBody"]</p>
                <button class="btn btn-outline-success btn-sm mt-2" @onclick='() => showGuestThankYou = false'>
                    @L["Comments_WriteAnother"]
                </button>
            </div>
        }

        @* Comment List *@
        @if (comments.Count == 0)
        {
            <p class="text-muted">@L["Comments_NoComments"]</p>
        }
        else
        {
            @foreach (var comment in comments)
            {
                <CommentNode Comment="comment" Depth="0" IsAuthenticated="isAuthenticated" />
            }
        }
    }
</div>

@code {
    [Parameter] public Guid PostId { get; set; }

    private List<CommentDto> comments = new();
    private bool isAuthenticated;
    private bool isLoading = true;
    private const int MaxCommentLength = 8000;
    private bool isSubmitting;
    private bool showGuestThankYou;
    private string newCommentText = "";
    private string newCommentGuestName = "";
    private string newCommentGuestEmail = "";
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        var user = await Api.GetCurrentUserAsync();
        isAuthenticated = user is not null;

        await LoadCommentsAsync();
    }

    private async Task LoadCommentsAsync()
    {
        isLoading = true;
        error = null;
        try
        {
            var result = await Api.GetCommentsAsync(PostId);
            if (result is not null)
            {
                comments = result;
            }
            else
            {
                error = L["Comments_FailedLoad"];
            }
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SubmitTopLevelCommentAsync()
    {
        if (string.IsNullOrWhiteSpace(newCommentText) || isSubmitting) return;
        isSubmitting = true;
        error = null;

        try
        {
            var result = await Api.AddCommentAsync(PostId, newCommentText, newCommentGuestName, newCommentGuestEmail);

            if (result is not null)
            {
                if (result.IsApproved)
                {
                    // Authenticated user: insert immediately at the top
                    comments.Insert(0, result);
                    newCommentText = "";
                    newCommentGuestName = "";
                    newCommentGuestEmail = "";
                }
                else
                {
                    // Guest: show thank-you, the comment will appear after approval
                    newCommentText = "";
                    newCommentGuestName = "";
                    newCommentGuestEmail = "";
                    showGuestThankYou = true;
                }
            }
            else
            {
                error = L["Comments_FailedPost"];
            }
        }
        catch (Exception ex)
        {
            error = L["Common_SomethingWentWrong", ex.Message];
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
